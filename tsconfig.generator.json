{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "rootDir": "ai-driven-sdd-angular",
        "outDir": "dist-generator",
        "esModuleInterop": true,
        "moduleResolution": "Node",
        "types": [
            "node"
        ],
        "strict": true
    },
    "include": [
        "ai-driven-sdd-angular/generators/**/*"
    ],
    "exclude": [
        "**/*.spec.ts"
    ]
}